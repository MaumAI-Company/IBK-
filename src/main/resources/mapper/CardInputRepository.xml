<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="kr.co.ibk.repository.CardInputRepository">
    <select id="getTotalCount" resultType="int">
        SELECT
            COUNT(*)
        FROM
            CARD_INPUT ci
        LEFT JOIN CARD_OUTPUT co ON ci.TSTM_YMD = co.TSTM_YMD
            AND ci.TSTM_NO = co.TSTM_NO
            AND ci.BRCD = co.BRCD
        WHERE ci.BRCD is not null
        <include refid="where"></include>
    </select>

    <select id="getList" resultType="CardInputInfo" parameterType="CardInputForm">
        SELECT
            <include refid="columns"></include>
        FROM
            CARD_INPUT ci
        LEFT JOIN CARD_OUTPUT co ON ci.TSTM_YMD = co.TSTM_YMD
            AND ci.TSTM_NO = co.TSTM_NO
            AND ci.BRCD = co.BRCD
        WHERE ci.BRCD is not null
        <include refid="where"></include>
        ORDER BY
        <choose>
            <when test="sortingTarget != null and sortingTarget == 1">
                ci.NO
            </when>
            <otherwise>
                ci.NO
            </otherwise>
        </choose>
        <choose>
            <when test="sorting != null and sorting == 'asc'">
                ASC
            </when>
            <otherwise>
                DESC
            </otherwise>
        </choose>
        <include refid="kr.co.ibk.repository.CommonRepository.paging" />
    </select>

    <sql id="columns">
        ci.HDQR_BOB_DCD ,
        ci.CDN ,
        ci.FRRG_TS ,
        ci.BDGT_TSTM_USE_HMS,
        ci.AMSL_AMT ,
        ci.AFST_NM ,
        ci.BZDY_YN,
        ci.TSTM_YMD ,
        ci.TSTM_NO ,
        ci.BRCD ,
        ci.NO ,
        ci.TPBS_NM ,
        ci.AFST_BZN ,
        ci.AMSL_AFST_NO ,
        ci.AFST_TPBCD ,
        ci.AFST_DTL_ADR ,
        ci.BRNC_ADR ,
        co.BDGT_ITEX_FRCS_CON ,
        co.BDGT_BSNS_FRCS_CON ,
        co.BDGT_PRFR_RSN_FRCS_CON ,
        co.RSRE_YMD
    </sql>

    <sql id="where">
        /*일자 검색*/
        <if test="'Y'.toString() != searchAllDateAt">
            <if test="searchStartDate != null and searchStartDate != ''">
                <![CDATA[
                    AND DATE_FORMAT( co.RSRE_YMD, '%Y.%m.%d') >= #{searchStartDate}
                 ]]>
            </if>
            <if test="searchEndDate != null and searchEndDate != ''">
                <![CDATA[
                    AND DATE_FORMAT( co.RSRE_YMD, '%Y.%m.%d') <= #{searchEndDate}
                 ]]>
            </if>
        </if>

        /*대상 검색*/
        <if test="searchTarget != null and searchTarget != ''">
            AND ci.HDQR_BOB_DCD = #{searchTarget}
        </if>

        /*검색어 검색*/
        <if test="searchJsonMap != null">
            <foreach collection="searchJsonMap" item="value" index="key">
                <if test="key == 'BDMN_ITEX_MNGM_NO'">
                    AND co.BDGT_BSNS_FRCS_CON LIKE CONCAT('%', #{value}, '%')
                </if>
                <if test="key != 'BDMN_ITEX_MNGM_NO' and key != 'BDGT_PRFR_RSN_FRCS_CON' and key != 'BDGT_BSNS_FRCS_CON'">
                    AND ci.${key} LIKE CONCAT('%', #{value}, '%')
                </if>
                <if test="key != 'BDMN_ITEX_MNGM_NO' and (key == 'BDGT_PRFR_RSN_FRCS_CON' or key == 'BDGT_BSNS_FRCS_CON')">
                    AND co.${key} LIKE CONCAT('%', #{value}, '%')
                </if>
            </foreach>
        </if>
    </sql>

    <select id="getDetail" resultType="CardInputInfo" parameterType="CardInputForm">
        SELECT
            <include refid="columns"></include>
        FROM
            CARD_INPUT ci
        LEFT JOIN CARD_OUTPUT co ON ci.TSTM_YMD = co.TSTM_YMD
            AND ci.TSTM_NO = co.TSTM_NO
            AND ci.BRCD = co.BRCD
        WHERE ci.BRCD is not null
            AND ci.TSTM_YMD = #{tstmYmd}
            AND ci.TSTM_NO = #{tstmNo}
            AND ci.BRCD = #{brcd}
        <!--<choose>
            <when test="loadType != null and loadType != ''">
                <include refid="where"></include>
                <if test="loadType == 'prev'">

                </if>
                <if test="loadType == 'next'">

                </if>
            </when>
            <otherwise>
                AND ci.TSTM_YMD = #{tstmYmd}
                AND ci.TSTM_NO = #{tstmNo}
                AND ci.BRCD = #{brcd}
            </otherwise>
        </choose>-->
    </select>

    <select id="getAllList" resultType="CardInputInfo" parameterType="CardInputForm">
        SELECT
            <include refid="columns"></include>
        FROM
            CARD_INPUT ci
        LEFT JOIN CARD_OUTPUT co ON ci.TSTM_YMD = co.TSTM_YMD
            AND ci.TSTM_NO = co.TSTM_NO
            AND ci.BRCD = co.BRCD
        WHERE ci.BRCD is not null
            <include refid="where"></include>
        ORDER BY
            ci.FRRG_TS
        <choose>
            <when test="sorting != null and sorting == 'asc'">
                ASC
            </when>
            <otherwise>
                DESC
            </otherwise>
        </choose>
    </select>

    <select id="getInputKey" resultType="CardInputInfo" parameterType="CardInputForm">
        SELECT
            ci.TSTM_YMD ,
            ci.TSTM_NO ,
            ci.BRCD
        FROM
            CARD_INPUT ci
        LEFT JOIN CARD_OUTPUT co ON ci.TSTM_YMD = co.TSTM_YMD
            AND ci.TSTM_NO = co.TSTM_NO
            AND ci.BRCD = co.BRCD
        WHERE
            ci.BRCD is not null
        <include refid="where"></include>
        <choose>
            <when test="(sorting == 'asc' and loadType == 'prev') or (sorting == 'desc' and loadType == 'next')">
                and ci.NO &lt; #{no} <!--ci.NO < #{no}-->
            </when>
            <when test="(sorting == 'asc' and loadType == 'next') or (sorting == 'desc' and loadType == 'prev')">
                and ci.NO &gt; #{no} <!--ci.NO > #{no}-->
            </when>
        </choose>
        ORDER BY
        ci.NO
        <choose>
            <when test="(sorting == 'asc' and loadType == 'next') or (sorting == 'desc' and loadType == 'prev')">
                ASC
            </when>
            <when test="(sorting == 'asc' and loadType == 'prev') or (sorting == 'desc' and loadType == 'next')">
                DESC
            </when>
        </choose>
        limit 1
    </select>
</mapper>