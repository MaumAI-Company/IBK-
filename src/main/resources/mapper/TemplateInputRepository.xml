<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="kr.co.ibk.repository.TemplateInputRepository">
    <insert id="insertList" parameterType="map">
        INSERT INTO TEMPLATE_INPUT
        (
        COL_NAME,
        TEMPLATE_ID,
        INOUT_GBN,
        SNO
        )
        VALUES
        <foreach collection="dataArr" item="item" separator=",">
            (
            #{item.name},
            #{id},
            #{gbn},
            #{item.sno}
            )
        </foreach>
    </insert>

    <select id="getPartList" resultType="TemplateInputInfo" parameterType="map">
        select
        ti.COL_NAME
        ,ti.TEMPLATE_ID
        ,ti.INOUT_GBN
        ,ti.SNO
        <if test="gbn != null and gbn != '' and gbn == 'INPUT'">
            ,ti.COL_NAME as inputColumnType
        </if>
        <if test="gbn != null and gbn != '' and gbn == 'OUTPUT'">
            ,ti.COL_NAME as outputColumnType
        </if>
        from TEMPLATE_INPUT ti
        where ti.TEMPLATE_ID = #{id}
        <if test="gbn != null and gbn != ''">
            and ti.INOUT_GBN = #{gbn}
        </if>
        order by ti.INOUT_GBN asc
    </select>
</mapper>