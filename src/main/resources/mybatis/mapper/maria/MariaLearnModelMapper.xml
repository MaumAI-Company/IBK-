<?xml version="1.0" encoding="UTF-8"?><!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mindslab.web.mapper.maria.MariaLearnModelMapper">
   
    <select id="getLearnModelTotalCount" parameterType="com.mindslab.web.vo.LearnModelVO" resultType="int">
        SELECT 
            COUNT(1)
        FROM 
	       ( SELECT 
	            <include refid="learn_model_columns"><property name="alias" value="lm."/></include>
	            , (SELECT hm.MEM_NAME FROM HC_MEMBER hm WHERE hm.MEM_ID = lm.REG_ID) AS MEM_NAME
	        FROM 
	        	LEARNING_MODEL AS lm
	        WHERE 
	        	1=1 ) lm
        WHERE 
        	1=1
        	AND lm.DELETE_YN != 'Y'
        	<include refid="searchLearn" />
    </select>

    <select id="getLearnModelList" parameterType="com.mindslab.web.vo.LearnModelVO" resultType="com.mindslab.web.vo.LearnModelVO">
        SELECT 
			*
        FROM 
	       ( SELECT 
	            <include refid="learn_model_columns"><property name="alias" value="lm."/></include>
	            , (SELECT hm.MEM_NAME FROM HC_MEMBER hm WHERE hm.MEM_ID = lm.REG_ID) AS MEM_NAME
	        FROM 
	        	LEARNING_MODEL AS lm
	        WHERE 
	        	1=1 ) lm
        WHERE 
        	1=1
        	AND lm.DELETE_YN != 'Y'
        	<include refid="searchLearn" />
        <if test="createDtmOrd != null and (createDtmOrd == 'asc' or createDtmOrd == 'desc')">
        ORDER BY 
        	ID ${createDtmOrd}
       	</if>
    	    <include refid="com.mindslab.web.mapper.maria.MariaCommonMapper.paging" />
    </select>
    
    <select id="getLearnModelInfo" parameterType="com.mindslab.web.vo.LearnModelVO" resultType="com.mindslab.web.vo.LearnModelVO">
        SELECT 
			*
        FROM 
	       ( SELECT 
	            <include refid="learn_model_columns"><property name="alias" value="lm."/></include>
	            , (SELECT hm.MEM_NAME FROM HC_MEMBER hm WHERE hm.MEM_ID = lm.REG_ID) AS MEM_NAME
	        FROM 
	        	LEARNING_MODEL AS lm
	        WHERE 
	        	1=1 ) lm
        WHERE 
        	1=1
        	AND lm.DELETE_YN != 'Y'
			AND lm.ID = #{id}
    </select>
        
    
    <update id="deployStatusUpdate" parameterType="com.mindslab.web.vo.LearnModelVO">
		UPDATE LEARNING_MODEL
	    SET 
	    	MOD_ID = #{modId}
	    	, MOD_DT = current_timestamp()
			, DEPLOY_STATUS = #{deployStatus}
	    WHERE ID = #{id}
        	AND DELETE_YN != 'Y'
    </update>
    
    
    <select id="getDeployingCount" parameterType="com.mindslab.web.vo.LearnModelVO" resultType="int">
        SELECT 
            COUNT(1)
        FROM 
	       ( SELECT 
	            <include refid="learn_model_columns"><property name="alias" value="lm."/></include>
	            , (SELECT hm.MEM_NAME FROM HC_MEMBER hm WHERE hm.MEM_ID = lm.REG_ID) AS MEM_NAME
	        FROM 
	        	LEARNING_MODEL AS lm
	        WHERE 
	        	1=1 ) lm
        WHERE 
        	1=1
        	AND lm.DELETE_YN != 'Y'
        	AND lm.DEPLOY_STATUS = '4'
    </select>
    
    <sql id="learn_model_columns">
		${alias}ID
		, ${alias}LEARNING_ID
		, ${alias}REG_ID
		, ${alias}REG_DT
		, ${alias}MOD_ID
		, ${alias}MOD_DT
		, ${alias}LEARN_NAME
		, ${alias}EPOCH
		, ${alias}LEARNING_RATE
		, ${alias}BATCH_SIZE
		, ${alias}LEARNING_RESULT
		, ${alias}DEPLOY_STATUS
		, ${alias}DEPLOY_DT
		, ${alias}ROLLBACK_DT
		, ${alias}RESULT_CODE
		, ${alias}RESULT_MSG
		, ${alias}CREATE_DTM
		, ${alias}DELETE_YN
    </sql>
    
    <!-- MariaDB LEARING_MODEL 테이블 검색 -->
	<sql id="searchLearn">
		<!-- 대상 검색 키워드가 있을 때 -->
		<if test="searchKeyword != null and searchKeyword != '' and searchKeyword != 'undefined' ">
			<choose>
				<!-- 대상 검색 유형이 있을 때 -->
				<when test="searchType != null and searchType != ''">
					<choose>
						<when test="'all'.equals(searchType)">
						AND
						(
							LEARN_NAME LIKE CONCAT('%', #{searchKeyword}, '%')
							OR MEM_NAME LIKE CONCAT('%', #{searchKeyword}, '%')
						)
						</when>
						<when test="'learn'.equals(searchType)">
							AND LEARN_NAME LIKE CONCAT('%', #{searchKeyword}, '%')
						</when>
						<when test="'em'.equals(searchType)">
							AND MEM_NAME LIKE CONCAT('%', #{searchKeyword}, '%')
						</when>
					</choose>
				</when>
				<!-- 검색 유형이 없을 때 -->
				<otherwise>
						AND
							1 = 1
				</otherwise>
			</choose>
		</if>
		
		<!-- deployStatus -->
		<if test="deployStatus != null and deployStatus != '' and deployStatus != 'undefined'">
			<choose>
				<when test="'all'.equals(deployStatus)">
				AND
				(
					upper(DEPLOY_STATUS) LIKE CONCAT('%', '2', '%')
					OR upper(DEPLOY_STATUS) LIKE CONCAT('%', '4', '%')
					OR upper(DEPLOY_STATUS) LIKE CONCAT('%', '1', '%')
					OR upper(DEPLOY_STATUS) LIKE CONCAT('%', '0', '%')
				)
				</when>
				<when test="'finish'.equals(deployStatus)">
					AND upper(DEPLOY_STATUS) LIKE CONCAT('%', '2', '%')
				</when>
				<when test="'deploying'.equals(deployStatus)">
					AND upper(DEPLOY_STATUS) LIKE CONCAT('%', '4', '%')
				</when>
				<when test="'error'.equals(deployStatus)">
					AND upper(DEPLOY_STATUS) LIKE CONCAT('%', '1', '%')
				</when>
				<when test="'regist'.equals(deployStatus)">
					AND upper(DEPLOY_STATUS) LIKE CONCAT('%', '0', '%')
				</when>
				<!-- 검색 유형이 없을 때 -->
				<otherwise>
				</otherwise>
			</choose>
		</if>
				
		<!-- 날짜 검색 유형이 있을 때 -->
		<if test="searchStartDate != null and searchStartDate != ''">
			<![CDATA[ 
				AND DATE_FORMAT( CREATE_DTM, '%Y-%m-%d') >= #{searchStartDate}
			 ]]>
		</if>
		<if test="searchEndDate != null and searchEndDate != ''">
			<![CDATA[ 
				AND DATE_FORMAT( CREATE_DTM, '%Y-%m-%d') <= #{searchEndDate}
			 ]]>
		</if>
	</sql>
</mapper>


	

