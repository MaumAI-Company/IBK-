<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="kr.co.ibk.repository.FileInfoRepository">
    <sql id="Base_Column_List">
        tfi.fl_pid
        , tfi.dv_ty
		, tfi.fl_nm
		, tfi.chg_fl_nm
		, tfi.fl_sz
		, tfi.fl_sno
		, tfi.fl_extsn
		, tfi.fl_pth
		, tfi.reg_dtm
		, tfi.data_pid
		, tfi.table_nm
    </sql>

    <sql id="Default_From">
        from tbl_file_info as tfi
    </sql>

    <sql id="Search_Where_Clause">
        <where>
            <if test="dataPid != null">
                and tfi.data_pid = #{dataPid}
            </if>
            <if test="tableNm != null">
                and tfi.table_nm = #{tableNm}
            </if>
            <if test="dvTy != null">
                and tfi.dv_ty = #{dvTy}
            </if>
            <if test="chgFlNm != null">
                and tfi.chg_fl_nm = #{chgFlNm}
            </if>
            <if test="flPth != null">
                and tfi.fl_pth = #{flPth}
            </if>
        </where>
    </sql>

    <select id="selectList" parameterType="FileInfoForm" resultType="FileInfo">
        select
            <include refid="Base_Column_List"></include>
            <include refid="Default_From"></include>
            <include refid="Search_Where_Clause"></include>
    </select>

    <insert id="setInsert" keyColumn="fl_pid" keyProperty="flPid"
            parameterType="kr.co.ibk.domain.web.FileInfo"
            useGeneratedKeys="true">
        insert into tbl_file_info (dv_ty, fl_nm, chg_fl_nm, fl_sz, fl_sno,
                                   fl_extsn, fl_pth, reg_dtm, data_pid, table_nm)
        values (#{dvTy,jdbcType=VARCHAR}, #{flNm,jdbcType=NVARCHAR}, #{chgFlNm,jdbcType=NVARCHAR},
                #{flSz,jdbcType=BIGINT}, #{flSno,jdbcType=INTEGER},
                #{flExtsn,jdbcType=VARCHAR}, #{flPth,jdbcType=NVARCHAR}, SYSDATE(),
                #{dataPid,jdbcType=BIGINT}, #{tableNm,jdbcType=NVARCHAR})
    </insert>

    <delete id="deleteByTableNmAndDataPid" parameterType="FileInfoForm">
        delete from tbl_file_info
        where table_nm = #{tableNm}
            and data_pid = #{dataPid}
        <if test="dvTy != null">
            and dv_ty = #{dvTy}
        </if>
    </delete>

    <delete id="deleteByPrimaryKeys" parameterType="list">
        DELETE FROM tbl_file_info
        WHERE fl_pid IN
        <foreach item="item" index="index" collection="list"
                 open="(" separator="," close=")">
            #{item}
        </foreach>
    </delete>
</mapper>
