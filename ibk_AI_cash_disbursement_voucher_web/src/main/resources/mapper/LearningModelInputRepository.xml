<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="kr.co.ibk.repository.LearningModelInputRepository">
    <insert id="insertList" parameterType="map">
        INSERT INTO LEARNING_MODEL_INPUT
        (
        COL_NAME,
        MODEL_ID,
        INOUT_GBN,
        SNO
        )
        VALUES
        <foreach collection="dataArr" item="item" separator=",">
            (
            #{item.name},
            #{id},
            #{gbn},
            #{item.sno}
            )
        </foreach>
    </insert>
    <select id="getList" resultType="LearningModelInputInfo" parameterType="Integer">
        select
        lmi.COL_NAME
        ,lmi.MODEL_ID
        ,lmi.INOUT_GBN
        from LEARNING_MODEL_INPUT lmi
        where lmi.MODEL_ID = #{id}
        order by lmi.INOUT_GBN asc
    </select>

    <select id="getPartList" resultType="LearningModelInputInfo" parameterType="map">
        select
        lmi.COL_NAME
        ,lmi.MODEL_ID
        ,lmi.INOUT_GBN
        <choose>
            <when test="gbn == 'INPUT' and learningType == 'CARD'">
                , lmi.COL_NAME AS inputColumnCardType
            </when>
            <when test="gbn == 'INPUT' and learningType == 'BILL'">
                , lmi.COL_NAME AS inputColumnBillType
            </when>
            <when test="gbn == 'OUTPUT' and learningType == 'CARD'">
                , lmi.COL_NAME AS outputColumnCardType
            </when>
            <when test="gbn == 'OUTPUT' and learningType == 'BILL'">
                , lmi.COL_NAME AS outputColumnBillType
            </when>
        </choose>
        from LEARNING_MODEL_INPUT lmi
        where lmi.MODEL_ID = #{id}
        <if test="gbn != null and gbn != ''">
            and lmi.INOUT_GBN = #{gbn}
        </if>
        order by lmi.INOUT_GBN asc
    </select>

    <delete id="delete" parameterType="Integer">
        delete from LEARNING_MODEL_INPUT
        where MODEL_ID = #{id}
    </delete>
</mapper>