<?xml version="1.0" encoding="UTF-8"?><!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mindslab.web.mapper.maria.MariaScanMapper">
   
    <select id="getScanTotalCount" parameterType="com.mindslab.web.vo.ScanVO" resultType="int">
        SELECT 
            COUNT(1)
        FROM 
	       ( SELECT 
	            <include refid="scan_result_columns"><property name="alias" value="sr."/></include>
	        FROM 
	        	SCAN_RESULT AS sr
	        WHERE 
	        	1=1 ) sr
        WHERE 
        	1=1
        	<include refid="com.mindslab.web.mapper.maria.MariaCommonMapper.searchScan" />
    </select>

    <select id="getScanList" parameterType="com.mindslab.web.vo.ScanVO" resultType="com.mindslab.web.vo.ScanVO">
        SELECT 
			*
        FROM 
	       ( SELECT 
	            <include refid="scan_result_columns"><property name="alias" value="sr."/></include>
	        FROM 
	        	SCAN_RESULT AS sr
	        WHERE 
	        	1=1 ) sr
        WHERE 
        	1=1
        	<include refid="com.mindslab.web.mapper.maria.MariaCommonMapper.searchScan" />
        <if test="createDtmOrd != null and (createDtmOrd == 'asc' or createDtmOrd == 'desc')">
        ORDER BY 
        	ID ${createDtmOrd}
       	</if>
    	    <include refid="com.mindslab.web.mapper.maria.MariaCommonMapper.paging" />
    </select>
    
    <select id="getScanListExcelDown" resultType="java.util.HashMap">
        SELECT 
			*
        FROM 
	       ( SELECT 
	            <include refid="scan_result_columns"><property name="alias" value="sr."/></include>
				, CONCAT(nvl(sr.level,''), '') as LEVEL_STR
				, CONCAT(nvl(sr.EDPS_CSN,''), '') as EDPS_CSN_STR
				, CONCAT(nvl(sr.REAL_CELL,''), '') as REAL_CELL_STR
				, CONCAT(nvl(sr.MONITOR_CELL,''), '') as MONITOR_CELL_STR
				, CONCAT(nvl(sr.PAPER_CELL,''), '') as PAPER_CELL_STR
	        FROM 
	        	SCAN_RESULT AS sr
	        WHERE 
	        	1=1 ) sr
        WHERE 
        	1=1
        	<include refid="com.mindslab.web.mapper.maria.MariaCommonMapper.searchScan" />
        <if test="createDtmOrd != null and (createDtmOrd == 'asc' or createDtmOrd == 'desc')">
        ORDER BY 
        	ID ${createDtmOrd}
       	</if>
    </select>
    <select id="getScanNextInfo" parameterType="com.mindslab.web.vo.ScanVO" resultType="com.mindslab.web.vo.ScanVO">
    	SELECT 
    		*
    	FROM 
    		SCAN_RESULT
	    WHERE
	    	1=1
	    	AND ID = ( 
		    	SELECT MIN(sr.ID)
		    	FROM (
				        SELECT 
							<include refid="scan_result_columns"><property name="alias" value="sr."/></include>
				        FROM 
				        	SCAN_RESULT sr
				        WHERE 
				        	1=1
				        	<include refid="com.mindslab.web.mapper.maria.MariaCommonMapper.searchScan" />
				        <if test="createDtmOrd != null and (createDtmOrd == 'asc' or createDtmOrd == 'desc')">
				        ORDER BY 
				        	ID ${createDtmOrd}
				       	</if>
			       	) sr
	       		<![CDATA[
		       WHERE ID > #{id}
		       ]]>
	       )
    </select>
    
    <select id="getScanPrevInfo" parameterType="com.mindslab.web.vo.ScanVO" resultType="com.mindslab.web.vo.ScanVO">
    	SELECT 
    		*
    	FROM 
    		SCAN_RESULT
	    WHERE
	    	1=1
	    	AND ID = ( 
		    	SELECT MAX(sr.ID)
		    	FROM (
				        SELECT 
							<include refid="scan_result_columns"><property name="alias" value="sr."/></include>
				        FROM 
				        	SCAN_RESULT sr
				        WHERE 
				        	1=1
				        	<include refid="com.mindslab.web.mapper.maria.MariaCommonMapper.searchScan" />
				        <if test="createDtmOrd != null and (createDtmOrd == 'asc' or createDtmOrd == 'desc')">
				        ORDER BY 
				        	ID ${createDtmOrd} 
				       	</if>
			       	) sr
	       		<![CDATA[
		       WHERE ID < #{id}
		       ]]>
	       )
    </select>
    
    <sql id="scan_result_columns">
		${alias}ID
		, ${alias}FILE_NAME
		, ${alias}level
		, ${alias}DETECT_RESULT
		, ${alias}DETECT_LOG
		, ${alias}CREATE_DTM
		, ${alias}EDPS_CSN
		, ${alias}DOC_ID
		, ${alias}IS_BATCH
		, ${alias}REAL_CELL
		, ${alias}MONITOR_CELL
		, ${alias}PAPER_CELL
    </sql>
    
</mapper>


	

